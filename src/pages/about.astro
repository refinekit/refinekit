---
import Layout from '~/layouts/Layout.astro'
import { getEntry, render } from 'astro:content'

// Load about page content from vault
const aboutPage = await getEntry('pages', 'about')
const { Content } = aboutPage ? await render(aboutPage) : { Content: null }
const title = aboutPage?.data.title || 'About'
const subtitle = aboutPage?.data.subtitle
---

<Layout title={title} description="About me">
  <div class="relative z-[1]">
    <div class="fade-up">
      <div class="py-8 pb-10 px-6 sm:px-8">
        <h1 class="flex flex-col gap-2">
          <span class="text-4xl sm:text-5xl tracking-tight">
            {title}
          </span>
          {subtitle && (
            <span class="text-muted-foreground font-light text-xl sm:text-2xl block tracking-wide text-balance">
              {subtitle}
            </span>
          )}
        </h1>
        {Content ? (
          <div class="markdown prose prose-lg dark:prose-invert max-w-none mt-6">
            <Content />
          </div>
        ) : (
          <p class="text-muted-foreground mt-6">No about page content found. Create an about.md file in your vault.</p>
        )}
      </div>
    </div>
  </div>
</Layout>
