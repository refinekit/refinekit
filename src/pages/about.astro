---
import Layout from '~/layouts/Layout.astro'
import { getEntry, render } from 'astro:content'

// Load about page content from vault
const aboutPage = await getEntry('pages', 'about')
const { Content } = aboutPage ? await render(aboutPage) : { Content: null }
const title = aboutPage?.data.title || 'About'
---

<Layout title={title} description="About me">
  <div class="relative z-[1]">
    <div class="fade-up">
      <div class="py-8 pb-10 px-6 sm:px-8">
        {Content ? (
          <div class="prose prose-lg dark:prose-invert max-w-none">
            <Content />
          </div>
        ) : (
          <p class="text-muted-foreground">No about page content found. Create an about.md file in your vault.</p>
        )}
      </div>
    </div>
  </div>
</Layout>
